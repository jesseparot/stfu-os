# stfu-os — Variables d'environnement
# Copier ce fichier : cp .env.example .env
# Remplir les valeurs, puis sourcer dans ~/.zshrc :
#   [ -f "$HOME/stfu-os/.env" ] && { set -a; source "$HOME/stfu-os/.env"; set +a; }
# Voir tuto/secrets-setup.md pour le guide complet.

# Airtable — personal access token (pat...)
AIRTABLE_API_KEY=

# Google Workspace — identifiants OAuth partagés (voir note Slite privée)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Google Workspace — votre email Google (utilisé par les skills pour Drive/Docs/Sheets/Slides)
GOOGLE_USER_EMAIL=

# Lemlist — clé API (Settings > Integrations > API)
LEMLIST_API_KEY=

# Dropcontact — access token (Dashboard > section API)
DROPCONTACT_ACCESS_TOKEN=

# Linkup — clé API (app.linkup.so/account)
LINKUP_API_KEY=
